{
  "draftId": "ab8c5306-eb41-4ba9-9d27-5a9fb3aa542a",
  "title": "EduHub | Aggressive Luxury-Brutalist Header & Footer",
  "htmlContent": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"view-transition\" content=\"same-origin\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js\"></script>\n  <style>\n    @import url('https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&f[]=playfair-display@400&f[]=jet-brains-mono@400&display=swap');\n\n    :root {\n      --bg: #f5f5f5;\n      --bg-white: #ffffff;\n      --black: #000000;\n      --black-mid: #0d0d0d;\n      --gray-a: #666666;\n      --gray-b: #999999;\n      --gray-c: #cccccc;\n      --gray-d: #e5e5e5;\n      --border: rgba(0,0,0,0.08);\n      --echo-1: #d1d1d1;\n      --echo-2: #dbdbdb;\n      --echo-3: #e5e5e5;\n      --echo-4: #efefef;\n      --font-display: 'Clash Display', sans-serif;\n      --font-body: 'Satoshi', sans-serif;\n      --font-serif: 'Playfair Display', serif;\n      --font-mono: 'JetBrains Mono', monospace;\n      --easing: cubic-bezier(0.8, 0, 0.1, 1);\n    }\n\n    body {\n      font-family: var(--font-body);\n      background-color: var(--bg);\n      color: var(--black);\n      -webkit-font-smoothing: antialiased;\n    }\n\n    @view-transition { navigation: auto; }\n    ::view-transition-old(root),\n    ::view-transition-new(root) {\n      animation-duration: 0.5s;\n      animation-timing-function: var(--easing);\n    }\n\n    .clash { font-family: var(--font-display); }\n    .serif { font-family: var(--font-serif); }\n    .mono { font-family: var(--font-mono); }\n\n    /* Typographic Echo Effect */\n    .echo-bg {\n      position: absolute;\n      top: 0; left: 0; right: 0;\n      font-family: var(--font-display);\n      font-size: clamp(80px, 14vw, 240px);\n      font-weight: 700;\n      line-height: 0.8;\n      letter-spacing: -0.06em;\n      text-align: center;\n      pointer-events: none;\n      user-select: none;\n      z-index: 0;\n    }\n    .echo-bg-1 { color: var(--echo-1); transform: translate(-0.06em, -0.06em); }\n    .echo-bg-2 { color: var(--echo-2); transform: translate(-0.12em, -0.12em); }\n    .echo-bg-3 { color: var(--echo-3); transform: translate(-0.18em, -0.18em); }\n\n    /* Ultra-Refined Glassmorphism */\n    .glass {\n      background: rgba(255, 255, 255, 0.65);\n      backdrop-filter: blur(40px);\n      -webkit-backdrop-filter: blur(40px);\n      border: 1px solid rgba(255, 255, 255, 0.5);\n      box-shadow: 0 10px 40px rgba(0,0,0,0.04);\n    }\n\n    /* Neo-Brutal Shadow Depth */\n    .neo-depth {\n      box-shadow: \n        20px 20px 60px #d9d9d9, \n        -20px -20px 60px #ffffff,\n        inset 0 0 0 1px var(--border);\n      transition: transform 0.4s var(--easing), box-shadow 0.4s var(--easing);\n    }\n    .neo-depth:hover {\n      transform: translateY(-8px) scale(1.01);\n      box-shadow: \n        30px 30px 80px #cccccc, \n        -30px -30px 80px #ffffff;\n    }\n\n    /* Oversized Titles */\n    .section-title {\n      font-family: var(--font-display);\n      font-size: clamp(48px, 12vw, 160px);\n      font-weight: 700;\n      letter-spacing: -0.07em;\n      line-height: 0.8;\n      text-transform: uppercase;\n      color: var(--black);\n    }\n\n    /* Hero entrance */\n    @keyframes hero-rise {\n      from { opacity: 0; transform: translateY(30px); filter: blur(20px); }\n      to { opacity: 1; transform: translateY(0); filter: blur(0); }\n    }\n    .hero-anim { animation: hero-rise 1200ms var(--easing) both; }\n    \n    @keyframes thinking-dot {\n      0%, 100% { transform: scale(1); opacity: 0.4; }\n      50% { transform: scale(1.3); opacity: 1; }\n    }\n    .dot-pulse { animation: thinking-dot 1s infinite; }\n\n    /* Custom Scrollbar for Brutalist feel */\n    ::-webkit-scrollbar {\n      width: 12px;\n    }\n    ::-webkit-scrollbar-track {\n      background: var(--bg);\n    }\n    ::-webkit-scrollbar-thumb {\n      background: var(--black);\n      border: 3px solid var(--bg);\n    }\n\n    .sc-card:hover .sc-card-inner {\n      filter: none;\n      transform: scale(1.05);\n    }\n\n    .ripple {\n      position: relative;\n      overflow: hidden;\n    }\n    .ripple:after {\n      content: \"\";\n      position: absolute;\n      left: 50%; top: 50%;\n      width: 5px; height: 5px;\n      background: rgba(255,255,255,0.4);\n      opacity: 0;\n      border-radius: 100%;\n      transform: scale(1, 1) translate(-50%);\n      transform-origin: 50% 50%;\n    }\n    .ripple:active:after {\n      animation: ripple 0.6s ease-out;\n    }\n    @keyframes ripple {\n      0% { transform: scale(0, 0); opacity: 0.5; }\n      100% { transform: scale(40, 40); opacity: 0; }\n    }\n\n    html { scroll-behavior: smooth; }\n  </style>\n</head>\n<body>\n  <div class=\"min-h-screen\">\n    <!-- Navigation -->\n    <nav class=\"sticky top-0 z-[200] h-[120px] glass border-b border-black/[0.05] flex items-center justify-between px-6 sm:px-12 lg:px-20 header\" style=\"view-transition-name: header;\">\n      <a href=\"#\" id=\"nav-logo\" class=\"clash text-[42px] font-bold tracking-[-0.08em] text-[var(--black)]\">\n        EDUHUB_\n      </a>\n      <div class=\"hidden md:flex items-center gap-10 lg:gap-14\">\n        <a href=\"#courses\" id=\"nav-link-courses\" class=\"text-[11px] font-bold tracking-[0.2em] uppercase hover:text-[var(--gray-b)] transition-colors\">Courses</a>\n        <a href=\"#reels\" id=\"nav-link-reels\" class=\"text-[11px] font-bold tracking-[0.2em] uppercase hover:text-[var(--gray-b)] transition-colors\">Reels</a>\n        <a href=\"#playground\" id=\"nav-link-playground\" class=\"text-[11px] font-bold tracking-[0.2em] uppercase hover:text-[var(--gray-b)] transition-colors\">Playground</a>\n      </div>\n      <div class=\"flex items-center gap-6\">\n        <div class=\"hidden sm:flex items-center gap-2 text-[12px] font-bold\">\n          <span class=\"text-[var(--gray-a)] uppercase tracking-wider\">Balance</span>\n          <span class=\"clash bg-[var(--black)] text-white px-2 py-0.5 rounded-sm\">100 EC</span>\n        </div>\n        <button id=\"nav-get-started-btn\" class=\"ripple px-8 py-3 bg-[var(--black)] text-white text-[11px] font-bold tracking-[0.15em] hover:bg-white hover:text-black hover:border-[var(--black)] border border-transparent transition-all\">\n          JOIN NOW\n        </button>\n      </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"pt-24 sm:pt-32 pb-20 px-6 sm:px-12 lg:px-20 relative overflow-hidden min-h-[92vh] flex items-center\">\n      <div class=\"w-full max-w-[1400px] mx-auto relative\">\n        <div class=\"flex flex-col items-center justify-center relative\">\n          <div class=\"hero-anim flex items-center gap-4 text-[12px] font-bold tracking-[0.3em] uppercase text-[var(--black)] mb-10\">\n            <span class=\"w-12 h-[2px] bg-[var(--black)]\"></span>\n            PREMIUM AI LABS\n            <span class=\"w-12 h-[2px] bg-[var(--black)]\"></span>\n          </div>\n\n          <!-- Aggressive headline with staggered reveals -->\n          <div class=\"relative text-center mb-12 w-full\">\n            <span class=\"echo-bg echo-bg-3\">EVOLVE.</span>\n            <span class=\"echo-bg echo-bg-2\">EVOLVE.</span>\n            <span class=\"echo-bg echo-bg-1\">EVOLVE.</span>\n\n            <div class=\"relative z-10\">\n              <div class=\"clash tracking-[-0.08em] leading-[0.75]\">\n                <div class=\"hero-anim text-[clamp(80px,15vw,260px)] font-bold\">EVOLVE.</div>\n                <div class=\"hero-anim text-[clamp(60px,11vw,180px)] font-bold opacity-80\" style=\"animation-delay: 150ms;\">DEPLOY.</div>\n                <div class=\"hero-anim text-[clamp(40px,8vw,120px)] font-bold text-[var(--gray-a)] opacity-60\" style=\"animation-delay: 300ms;\">MASTER AI.</div>\n              </div>\n            </div>\n          </div>\n\n          <p class=\"hero-anim text-[18px] sm:text-[20px] text-[var(--gray-a)] max-w-[800px] text-center font-medium leading-[1.6] mb-14\" style=\"animation-delay: 450ms;\">\n            High-fidelity AI training for the next generation of architects. Build transformers, ship neural workflows, and refine your craft in our exclusive ecosystem.\n          </p>\n\n          <div class=\"hero-anim flex flex-col sm:flex-row gap-6 items-center\" style=\"animation-delay: 600ms;\">\n            <button id=\"hero-explore-courses-btn\" class=\"ripple px-12 py-5 bg-[var(--black)] text-white font-bold text-[14px] tracking-[0.1em] hover:scale-105 transition-transform\">\n              START CURRICULUM\n            </button>\n            <button id=\"hero-try-playground-link\" class=\"px-12 py-5 border-2 border-[var(--black)] font-bold text-[14px] tracking-[0.1em] hover:bg-[var(--black)] hover:text-white transition-all\">\n              OPEN PLAYGROUND\n            </button>\n          </div>\n\n          <div class=\"grid grid-cols-1 sm:grid-cols-3 gap-16 w-full max-w-[1000px] mt-24 pt-16 border-t-[3px] border-[var(--black)]\">\n            <div class=\"text-center sm:text-left\">\n              <div class=\"clash text-[56px] font-bold tracking-[-0.06em] leading-none\">1.2M</div>\n              <div class=\"text-[11px] font-bold tracking-[0.2em] uppercase text-[var(--gray-a)] mt-2\">Engineers active</div>\n            </div>\n            <div class=\"text-center sm:text-left\">\n              <div class=\"clash text-[56px] font-bold tracking-[-0.06em] leading-none\">4.98</div>\n              <div class=\"text-[11px] font-bold tracking-[0.2em] uppercase text-[var(--gray-a)] mt-2\">Platform Score</div>\n            </div>\n            <div class=\"text-center sm:text-left\">\n              <div class=\"clash text-[56px] font-bold tracking-[-0.06em] leading-none\">0ms</div>\n              <div class=\"text-[11px] font-bold tracking-[0.2em] uppercase text-[var(--gray-a)] mt-2\">Inference Lag</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Philosophy -->\n    <section class=\"py-32 px-6 sm:px-12 lg:px-20 max-w-[1400px] mx-auto\">\n      <div class=\"section-title mb-16\">Philosophy</div>\n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-12\">\n        <div class=\"neo-depth p-12 bg-white\">\n          <div class=\"clash text-[24px] font-bold mb-6 flex items-center gap-4\">\n            <span class=\"w-10 h-10 bg-black text-white flex items-center justify-center text-[18px]\">01</span>\n            PRECISION\n          </div>\n          <p class=\"text-[16px] text-[var(--gray-a)] leading-relaxed\">Brutal outcomes require precise methods. We strip away the fluff, focusing on production-grade RAG and agent orchestration.</p>\n        </div>\n        <div class=\"neo-depth p-12 bg-white\">\n          <div class=\"clash text-[24px] font-bold mb-6 flex items-center gap-4\">\n            <span class=\"w-10 h-10 bg-black text-white flex items-center justify-center text-[18px]\">02</span>\n            SKEPTICISM\n          </div>\n          <p class=\"text-[16px] text-[var(--gray-a)] leading-relaxed\">Question every model. Our curriculum teaches advanced evaluation frameworks to validate performance at scale.</p>\n        </div>\n        <div class=\"neo-depth p-12 bg-white\">\n          <div class=\"clash text-[24px] font-bold mb-6 flex items-center gap-4\">\n            <span class=\"w-10 h-10 bg-black text-white flex items-center justify-center text-[18px]\">03</span>\n            VELOCITY\n          </div>\n          <p class=\"text-[16px] text-[var(--gray-a)] leading-relaxed\">Speed is a feature. Build, test, and ship in record time using our optimized scaffolding and playground tools.</p>\n        </div>\n      </div>\n    </section>\n\n    <!-- Showcase -->\n    <section class=\"px-6 sm:px-12 lg:px-20 py-32\">\n      <div class=\"section-title mb-16\">Showcase</div>\n      <div class=\"grid grid-cols-12 gap-8\">\n        <div class=\"sc-card neo-depth col-span-12 lg:col-span-7 h-[500px] bg-[var(--gray-c)] relative overflow-hidden group\">\n          <div class=\"absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110\" style=\"background-image: url('https://images.unsplash.com/photo-1620712943543-bcc4628c945c?auto=format&fit=crop&q=80&w=2000'); filter: grayscale(1) brightness(0.8);\"></div>\n          <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent\"></div>\n          <div class=\"absolute bottom-10 left-10 text-white\">\n            <div class=\"text-[11px] font-bold tracking-[0.3em] uppercase mb-4\">System Design</div>\n            <div class=\"clash text-[40px] font-bold leading-none\">NEURAL ARCHITECTURES</div>\n          </div>\n        </div>\n        <div class=\"sc-card neo-depth col-span-12 lg:col-span-5 h-[500px] bg-[var(--black)] relative overflow-hidden group flex items-center justify-center\">\n           <iconify-icon icon=\"lucide:cpu\" class=\"text-[140px] text-white opacity-20\"></iconify-icon>\n           <div class=\"absolute bottom-10 left-10 text-white\">\n            <div class=\"text-[11px] font-bold tracking-[0.3em] uppercase mb-4\">Hardware</div>\n            <div class=\"clash text-[40px] font-bold leading-none\">TENSOR OPTIMIZATION</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- AI Playground -->\n    <section class=\"px-6 sm:px-12 lg:px-20 py-32 bg-[var(--black)] text-white overflow-hidden\" id=\"playground\">\n      <div class=\"max-w-[1400px] mx-auto\">\n        <div class=\"clash text-[clamp(48px,12vw,160px)] font-bold tracking-[-0.07em] leading-[0.8] mb-20 text-white opacity-90\">PLAYGROUND</div>\n        \n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12\">\n          <div class=\"lg:col-span-4 flex flex-col justify-center\">\n            <h3 class=\"clash text-[32px] font-bold mb-8 leading-tight\">DEPLOY AGENTS<br/>IN SECONDS.</h3>\n            <p class=\"text-[16px] text-white/50 leading-relaxed mb-10\">Our terminal allows you to test logic gates, tool-use protocols, and RAG retrieval accuracy in a real-time sandbox environment.</p>\n            \n            <div class=\"space-y-4\">\n              <button class=\"w-full py-4 px-6 border border-white/20 hover:border-white hover:bg-white hover:text-black text-[12px] font-bold tracking-[0.2em] transition-all text-left flex justify-between items-center group\">\n                LOAD AGENT_V4\n                <iconify-icon icon=\"lucide:chevron-right\" class=\"opacity-0 group-hover:opacity-100 transition-opacity\"></iconify-icon>\n              </button>\n              <button class=\"w-full py-4 px-6 border border-white/20 hover:border-white hover:bg-white hover:text-black text-[12px] font-bold tracking-[0.2em] transition-all text-left flex justify-between items-center group\">\n                TEST TOOL_BOX\n                <iconify-icon icon=\"lucide:chevron-right\" class=\"opacity-0 group-hover:opacity-100 transition-opacity\"></iconify-icon>\n              </button>\n            </div>\n          </div>\n\n          <div class=\"lg:col-span-8\">\n            <!-- Dark Terminal Theme -->\n            <div class=\"rounded-xl bg-[#080808] border border-white/10 shadow-2xl overflow-hidden\">\n              <div class=\"flex items-center justify-between px-6 py-4 border-b border-white/5 bg-[#111]\">\n                <div class=\"flex gap-2\">\n                  <div class=\"w-3 h-3 rounded-full bg-[#ff5f56]\"></div>\n                  <div class=\"w-3 h-3 rounded-full bg-[#ffbd2e]\"></div>\n                  <div class=\"w-3 h-3 rounded-full bg-[#27c93f]\"></div>\n                </div>\n                <div class=\"text-[10px] font-bold tracking-widest text-white/30 uppercase\">root@eduhub:~/agent_v4</div>\n                <div class=\"flex items-center gap-2\">\n                  <span class=\"text-[10px] text-white/40 uppercase font-bold tracking-tighter\">UTF-8</span>\n                </div>\n              </div>\n              <div class=\"p-8 mono text-[13px] leading-relaxed text-[#00ff41]/90\">\n                <div class=\"mb-4 text-white/40\">// Initializing neural weight matrix...</div>\n                <div class=\"flex gap-3 mb-2\">\n                  <span class=\"text-white/30\">$</span>\n                  <span>python3 deploy_agent.py --model=eduhub-large-v2</span>\n                </div>\n                <div class=\"text-white\">\n                  > Loading embeddings: [####################] 100%\n                </div>\n                <div class=\"text-white mt-1\">\n                  > Establishing secure websocket: CONNECTED\n                </div>\n                \n                <div class=\"mt-8 border-l-2 border-[#00ff41]/30 pl-4 py-2\">\n                  <div class=\"flex items-center gap-3\">\n                    <span class=\"text-[11px] font-bold text-[#00ff41]\">STATUS:</span>\n                    <div class=\"flex items-center gap-1\">\n                      <span class=\"w-1.5 h-1.5 rounded-full bg-[#00ff41] dot-pulse\"></span>\n                      <span class=\"text-[11px] uppercase tracking-widest animate-pulse\">THINKING_PROMPT_REASONING...</span>\n                    </div>\n                  </div>\n                  <div class=\"mt-4 opacity-50\">\n                    ANALYZING REPO STRUCTURE...<br/>\n                    IDENTIFYING LATENT VULNERABILITIES...<br/>\n                    SYNTHESIZING OPTIMAL TEST SUITE...\n                  </div>\n                </div>\n\n                <div class=\"mt-8 flex gap-4\">\n                  <button class=\"px-6 py-2 bg-[#00ff41] text-black font-bold text-[11px] hover:brightness-110 transition-all uppercase\">Execute</button>\n                  <button class=\"px-6 py-2 border border-[#00ff41] text-[#00ff41] font-bold text-[11px] hover:bg-[#00ff41]/10 transition-all uppercase\">Clear Logs</button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Featured Courses -->\n    <section class=\"px-6 sm:px-12 lg:px-20 py-32\" id=\"courses\">\n      <div class=\"section-title mb-20\">Courses</div>\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">\n        <!-- Course Card -->\n        <div class=\"neo-depth bg-white p-10 flex flex-col border border-[var(--border)] group\">\n          <div class=\"w-16 h-16 bg-black text-white flex items-center justify-center mb-10 transition-transform duration-500 group-hover:rotate-[360deg]\">\n            <iconify-icon icon=\"lucide:brain-circuit\" class=\"text-[32px]\"></iconify-icon>\n          </div>\n          <div class=\"text-[11px] font-bold tracking-[0.2em] text-[var(--gray-b)] uppercase mb-4\">Lab Series / 01</div>\n          <h3 class=\"clash text-[28px] font-bold leading-tight mb-6\">TRANSFORMER INTERNALS</h3>\n          <p class=\"text-[15px] text-[var(--gray-a)] leading-relaxed flex-1 mb-10\">Deep-dive into attention mechanisms and KV-caching. Build your own inference engine from scratch using raw tensors.</p>\n          <div class=\"pt-8 border-t border-[var(--border)] flex justify-between items-center\">\n            <div class=\"text-[12px] font-bold uppercase tracking-widest\">$299.00</div>\n            <button class=\"w-12 h-12 bg-black text-white flex items-center justify-center hover:scale-110 transition-transform\">\n              <iconify-icon icon=\"lucide:arrow-right\"></iconify-icon>\n            </button>\n          </div>\n        </div>\n        \n        <div class=\"neo-depth bg-white p-10 flex flex-col border border-[var(--border)] group\">\n          <div class=\"w-16 h-16 bg-black text-white flex items-center justify-center mb-10 transition-transform duration-500 group-hover:rotate-[360deg]\">\n            <iconify-icon icon=\"lucide:shield-check\" class=\"text-[32px]\"></iconify-icon>\n          </div>\n          <div class=\"text-[11px] font-bold tracking-[0.2em] text-[var(--gray-b)] uppercase mb-4\">Lab Series / 02</div>\n          <h3 class=\"clash text-[28px] font-bold leading-tight mb-6\">ADVERSARIAL RED-TEAMING</h3>\n          <p class=\"text-[15px] text-[var(--gray-a)] leading-relaxed flex-1 mb-10\">Master the art of breaking model guardrails. Learn advanced jailbreaking and automated alignment testing.</p>\n          <div class=\"pt-8 border-t border-[var(--border)] flex justify-between items-center\">\n            <div class=\"text-[12px] font-bold uppercase tracking-widest\">$349.00</div>\n            <button class=\"w-12 h-12 bg-black text-white flex items-center justify-center hover:scale-110 transition-transform\">\n              <iconify-icon icon=\"lucide:arrow-right\"></iconify-icon>\n            </button>\n          </div>\n        </div>\n\n        <div class=\"neo-depth bg-white p-10 flex flex-col border border-[var(--border)] group\">\n          <div class=\"w-16 h-16 bg-black text-white flex items-center justify-center mb-10 transition-transform duration-500 group-hover:rotate-[360deg]\">\n            <iconify-icon icon=\"lucide:database\" class=\"text-[32px]\"></iconify-icon>\n          </div>\n          <div class=\"text-[11px] font-bold tracking-[0.2em] text-[var(--gray-b)] uppercase mb-4\">Lab Series / 03</div>\n          <h3 class=\"clash text-[28px] font-bold leading-tight mb-6\">ELASTIC RAG SYSTEMS</h3>\n          <p class=\"text-[15px] text-[var(--gray-a)] leading-relaxed flex-1 mb-10\">Architect retrieval systems that scale. Focus on hybrid search, re-ranking, and dynamic context injection.</p>\n          <div class=\"pt-8 border-t border-[var(--border)] flex justify-between items-center\">\n            <div class=\"text-[12px] font-bold uppercase tracking-widest\">$279.00</div>\n            <button class=\"w-12 h-12 bg-black text-white flex items-center justify-center hover:scale-110 transition-transform\">\n              <iconify-icon icon=\"lucide:arrow-right\"></iconify-icon>\n            </button>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"glass text-black pt-48 pb-24 px-6 sm:px-12 lg:px-20 border-t border-black/[0.05] relative z-40\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-4 gap-20 mb-32\">\n        <div class=\"lg:col-span-2\">\n          <div class=\"clash text-[40px] font-bold tracking-tighter mb-8\">EDUHUB.</div>\n          <p class=\"text-black/40 text-[16px] max-w-[400px] leading-relaxed font-medium\">\n            The premier institute for luxury-brutalist AI engineering. Form follows function. Knowledge follows code.\n          </p>\n        </div>\n        <div>\n          <div class=\"text-[12px] font-bold tracking-[0.4em] uppercase text-black/20 mb-10\">Navigation</div>\n          <div class=\"flex flex-col gap-5\">\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">Curriculum</a>\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">Playground</a>\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">Research</a>\n          </div>\n        </div>\n        <div>\n          <div class=\"text-[12px] font-bold tracking-[0.4em] uppercase text-black/20 mb-10\">Connect</div>\n          <div class=\"flex flex-col gap-5\">\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">Twitter / X</a>\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">GitHub</a>\n            <a href=\"#\" class=\"text-[14px] hover:text-black/40 transition-colors\">LinkedIn</a>\n          </div>\n        </div>\n      </div>\n      <div class=\"pt-12 border-t border-black/[0.08] flex flex-col md:flex-row justify-between items-center gap-8\">\n        <div class=\"text-[11px] font-bold tracking-[0.3em] text-black/20 uppercase\">┬⌐ 2024 EDUHUB INTERNATIONAL AG. GENEVA.</div>\n        <div class=\"flex gap-8 text-[11px] font-bold tracking-[0.3em] text-black/20 uppercase\">\n          <a href=\"#\" class=\"hover:text-black transition-colors\">Privacy</a>\n          <a href=\"#\" class=\"hover:text-black transition-colors\">Terms</a>\n          <a href=\"#\" class=\"hover:text-black transition-colors\">Ethics</a>\n        </div>\n      </div>\n    </footer>\n  </div>\n</body>\n</html>"
}

